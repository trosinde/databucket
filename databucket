cmd_start()  { _require_local "start";  _compose up -d; echo "databucket started."; }
cmd_stop()   { _require_local "stop";   _compose down; echo "databucket stopped."; }
cmd_status() { _require_local "status"; _compose ps; }
cmd_logs()   { _require_local "logs";   _compose logs "${@:---tail=50}"; }

