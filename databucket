#!/usr/bin/env bash
set -euo pipefail

DATABUCKET_HOME="${DATABUCKET_HOME:-/opt/databucket}"
DATABUCKET_USER=""
DATABUCKET_PASS=""

# ============================================================
# GLOBAL FLAGS (parsed before command routing)
# ============================================================

_parse_global_flags() {
    while [ $# -gt 0 ]; do
        case "$1" in
            --as)
                shift
                DATABUCKET_USER="${1:-}"
                [ -z "$DATABUCKET_USER" ] && { echo "ERROR: --as requires a username"; exit 1; }
                shift
                if [ "${1:-}" = "--password" ]; then
                    shift; DATABUCKET_PASS="${1:-}"; shift
                else
                    read -rsp "Password for $DATABUCKET_USER: " DATABUCKET_PASS; echo ""
                fi
                ;;
            *)  ARGS+=("$1"); shift ;;
        esac
    done
}

ARGS=()
_parse_global_flags "$@"
set -- "${ARGS[@]:-}"

# ============================================================
# HELPERS
# ============================================================

_compose() {
    docker compose -f "$DATABUCKET_HOME/docker-compose.yaml" --env-file "$DATABUCKET_HOME/.env" "$@"
}

_s3_env() {
    set -a
    source "$DATABUCKET_HOME/.env"
    set +a
    export S3_ENDPOINT="${S3_ENDPOINT:-http://localhost:${MINIO_API_PORT:-9000}}"
    if [ -n "$DATABUCKET_USER" ]; then
        export AWS_ACCESS_KEY_ID="$DATABUCKET_USER"
        export AWS_SECRET_ACCESS_KEY="$DATABUCKET_PASS"
    else
        export AWS_ACCESS_KEY_ID="$MINIO_ROOT_USER"
        export AWS_SECRET_ACCESS_KEY="$MINIO_ROOT_PASSWORD"
    fi
}

_s3() {
    _s3_env
    python3 -c "
import boto3, sys, json
from botocore.config import Config
s3 = boto3.client('s3', endpoint_url='$S3_ENDPOINT',
    aws_access_key_id='$AWS_ACCESS_KEY_ID',
    aws_secret_access_key='$AWS_SECRET_ACCESS_KEY',
    config=Config(signature_version='s3v4'))
$1
"
}

_mc() {
    _s3_env
    _compose exec -T minio mc alias set local http://localhost:9000 "$AWS_ACCESS_KEY_ID" "$AWS_SECRET_ACCESS_KEY" --quiet 2>/dev/null || true
    _compose exec -T minio mc "$@"
}

# ============================================================
# SERVICE
# ============================================================

cmd_start()  { _compose up -d; echo "databucket started."; }
cmd_stop()   { _compose down; echo "databucket stopped."; }
cmd_status() { _compose ps; }
cmd_logs()   { _compose logs "${@:---tail=50}"; }

cmd_update() {
    echo "Updating databucket..."
    cd "$DATABUCKET_HOME"
    _compose pull
    _compose build mcp-server
    _compose up -d
    echo "databucket updated."
}

cmd_info() {
    _s3_env
    echo "databucket"
    echo "  Home:     $DATABUCKET_HOME"
    echo "  S3 API:   $S3_ENDPOINT"
    echo "  Console:  http://localhost:${MINIO_CONSOLE_PORT:-9001}"
    [ -n "$DATABUCKET_USER" ] && echo "  User:     $DATABUCKET_USER"
    echo ""
    echo "Services:"
    _compose ps --format "  {{.Name}}\t{{.Status}}"
    echo ""
    echo "Buckets:"
    _s3 "
for b in s3.list_buckets()['Buckets']:
    resp = s3.list_objects_v2(Bucket=b['Name'], MaxKeys=1)
    count = resp.get('KeyCount', 0)
    suffix = '(empty)' if count == 0 else ''
    print(f\"  {b['Name']} {suffix}\")
"
}

# ============================================================
# BUCKETS
# ============================================================

cmd_bucket_list() {
    _s3 "
for b in s3.list_buckets()['Buckets']:
    print(b['Name'])
"
}

cmd_bucket_create() {
    [ -z "${1:-}" ] && { echo "Usage: databucket bucket create <name>"; exit 1; }
    _s3 "
s3.create_bucket(Bucket='$1')
print('Created: $1')
"
    # Enable auto-indexing for the new bucket
    _mc event add local/"$1" arn:minio:sqs::indexer:webhook --event put,delete 2>/dev/null \
        && echo "Auto-indexing enabled for: $1" \
        || true
}

cmd_bucket_delete() {
    [ -z "${1:-}" ] && { echo "Usage: databucket bucket delete <name>"; exit 1; }
    _s3 "
s3.delete_bucket(Bucket='$1')
print('Deleted: $1')
"
}

cmd_bucket_info() {
    [ -z "${1:-}" ] && { echo "Usage: databucket bucket info <name>"; exit 1; }
    _s3 "
paginator = s3.get_paginator('list_objects_v2')
total_size = 0
total_count = 0
for page in paginator.paginate(Bucket='$1'):
    for obj in page.get('Contents', []):
        total_size += obj['Size']
        total_count += 1
def fmt(size):
    for u in ['B','KB','MB','GB','TB']:
        if size < 1024: return f'{size:.1f} {u}'
        size /= 1024
print(f'Bucket:  $1')
print(f'Objects: {total_count}')
print(f'Size:    {fmt(total_size)}')
"
}

# ============================================================
# DATA
# ============================================================

cmd_upload() {
    [ -z "${3:-}" ] && { echo "Usage: databucket upload <file> <bucket> <key> [--metadata k=v,k=v] [--tags k=v,k=v]"; exit 1; }
    _s3_env
    local file="$1" bucket="$2" key="$3"
    shift 3

    local metadata="" tags=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --metadata) shift; metadata="${1:-}"; shift || true ;;
            --tags)     shift; tags="${1:-}"; shift || true ;;
            *)          shift ;;
        esac
    done

    python3 -c "
import boto3
from botocore.config import Config
s3 = boto3.client('s3', endpoint_url='$S3_ENDPOINT',
    aws_access_key_id='$AWS_ACCESS_KEY_ID',
    aws_secret_access_key='$AWS_SECRET_ACCESS_KEY',
    config=Config(signature_version='s3v4'))
extra = {}
meta = '$metadata'
tags = '$tags'
if meta:
    extra['Metadata'] = dict(kv.split('=', 1) for kv in meta.split(','))
if tags:
    from urllib.parse import urlencode
    extra['Tagging'] = urlencode(dict(kv.split('=', 1) for kv in tags.split(',')))
s3.upload_file('$file', '$bucket', '$key', ExtraArgs=extra or None)
print('Uploaded: s3://$bucket/$key')
"
}

cmd_download() {
    [ -z "${3:-}" ] && { echo "Usage: databucket download <bucket> <key> <output>"; exit 1; }
    _s3 "
s3.download_file('$1', '$2', '$3')
print('Downloaded: $3')
"
}

cmd_ls() {
    [ -z "${1:-}" ] && { echo "Usage: databucket ls <bucket> [prefix]"; exit 1; }
    local bucket="$1" prefix="${2:-}"
    _s3 "
resp = s3.list_objects_v2(Bucket='$bucket', Prefix='$prefix', MaxKeys=200)
for obj in resp.get('Contents', []):
    size = f\"{obj['Size']:>10}\"
    mod = obj['LastModified'].strftime('%Y-%m-%d %H:%M')
    print(f'{size}  {mod}  {obj[\"Key\"]}')
if resp.get('IsTruncated'):
    print(f'... truncated ({resp[\"KeyCount\"]} shown)')
"
}

cmd_inspect() {
    [ -z "${2:-}" ] && { echo "Usage: databucket inspect <bucket> <key>"; exit 1; }
    _s3 "
head = s3.head_object(Bucket='$1', Key='$2')
tags_resp = s3.get_object_tagging(Bucket='$1', Key='$2')
tags = {t['Key']: t['Value'] for t in tags_resp['TagSet']}
meta = head.get('Metadata', {})
def fmt(size):
    for u in ['B','KB','MB','GB','TB']:
        if size < 1024: return f'{size:.1f} {u}'
        size /= 1024
print(f'Key:          $2')
print(f'Size:         {fmt(head[\"ContentLength\"])}')
print(f'Content-Type: {head.get(\"ContentType\", \"\")}')
print(f'Modified:     {head[\"LastModified\"].isoformat()}')
print(f'ETag:         {head[\"ETag\"]}')
if meta:
    print('Metadata:')
    for k, v in meta.items(): print(f'  {k}: {v}')
if tags:
    print('Tags:')
    for k, v in tags.items(): print(f'  {k}: {v}')
"
}

# ============================================================
# USERS
# ============================================================

cmd_user_list()   { _mc admin user list local; }
cmd_user_info()   { [ -z "${1:-}" ] && { echo "Usage: databucket user info <name>"; exit 1; }; _mc admin user info local "$1"; }

cmd_user_create() {
    [ -z "${1:-}" ] && { echo "Usage: databucket user create <name> [password]"; exit 1; }
    local username="$1"
    local password="${2:-}"
    if [ -z "$password" ]; then
        read -rsp "Password for $username (min 8 chars): " password; echo ""
        [ ${#password} -lt 8 ] && { echo "ERROR: Password must be at least 8 characters."; exit 1; }
    fi
    _mc admin user add local "$username" "$password"
    echo "Created: $username"
    echo "Next: databucket user policy $username readwrite"
}

cmd_user_delete() { [ -z "${1:-}" ] && { echo "Usage: databucket user delete <name>"; exit 1; }; _mc admin user remove local "$1"; echo "Deleted: $1"; }
cmd_user_enable() { [ -z "${1:-}" ] && { echo "Usage: databucket user enable <name>"; exit 1; }; _mc admin user enable local "$1"; echo "Enabled: $1"; }
cmd_user_disable(){ [ -z "${1:-}" ] && { echo "Usage: databucket user disable <name>"; exit 1; }; _mc admin user disable local "$1"; echo "Disabled: $1"; }

cmd_user_key_create() {
    [ -z "${1:-}" ] && { echo "Usage: databucket user key create <username>"; exit 1; }
    _mc admin user svcacct add local "$1"
}

cmd_user_key_list() {
    [ -z "${1:-}" ] && { echo "Usage: databucket user key list <username>"; exit 1; }
    _mc admin user svcacct list local "$1"
}

cmd_user_key_delete() {
    [ -z "${1:-}" ] && { echo "Usage: databucket user key delete <access-key>"; exit 1; }
    _mc admin user svcacct remove local "$1"
    echo "Deleted key: $1"
}

cmd_user_policy() {
    [ -z "${2:-}" ] && { echo "Usage: databucket user policy <name> <policy>"; echo ""; echo "Built-in policies: readonly, readwrite, writeonly"; echo "Custom policies:   databucket policy list"; exit 1; }
    _mc admin policy attach local "$2" --user "$1"
    echo "Attached '$2' to user '$1'"
}

# ============================================================
# POLICIES
# ============================================================

cmd_policy_list() { _mc admin policy list local; }
cmd_policy_info() { [ -z "${1:-}" ] && { echo "Usage: databucket policy info <name>"; exit 1; }; _mc admin policy info local "$1"; }

cmd_policy_create() {
    [ -z "${2:-}" ] && { echo "Usage: databucket policy create <name> <json-file>"; echo ""; _policy_create_help; exit 1; }
    local name="$1" file="$2"
    [ ! -f "$file" ] && { echo "ERROR: File not found: $file"; exit 1; }
    # Copy policy file into container and apply
    docker cp "$file" "$(_compose ps -q minio):/tmp/policy.json"
    _mc admin policy create local "$name" /tmp/policy.json
    echo "Created policy: $name"
}

cmd_policy_delete() {
    [ -z "${1:-}" ] && { echo "Usage: databucket policy delete <name>"; exit 1; }
    _mc admin policy remove local "$1"
    echo "Deleted policy: $1"
}

_policy_create_help() {
    cat <<'POLICYEOF'
Example: Allow read-only access to the 'curated' bucket only.

Save as curated-readonly.json:
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::curated",
        "arn:aws:s3:::curated/*"
      ]
    }
  ]
}

Then run:
  databucket policy create curated-readonly curated-readonly.json
  databucket user policy analyst curated-readonly
POLICYEOF
}

# ============================================================
# BACKUP
# ============================================================

cmd_backup() {
    local target="${1:-./databucket-backup}"
    _s3_env
    mkdir -p "$target"

    echo "Backing up databucket to $target ..."
    _s3 "
import os
paginator_buckets = s3.list_buckets()
for bucket in paginator_buckets['Buckets']:
    bname = bucket['Name']
    paginator = s3.get_paginator('list_objects_v2')
    for page in paginator.paginate(Bucket=bname):
        for obj in page.get('Contents', []):
            key = obj['Key']
            local_path = os.path.join('$target', bname, key)
            os.makedirs(os.path.dirname(local_path), exist_ok=True)
            s3.download_file(bname, key, local_path)
            print(f'  {bname}/{key}')
"
    echo "Backup complete: $target"
}

# ============================================================
# SEARCH
# ============================================================

cmd_search() {
    [ -z "${1:-}" ] && { echo "Usage: databucket search <query> [--bucket <name>] [--limit <n>]"; exit 1; }
    _s3_env
    local query="$1"
    shift

    local bucket="" limit=10
    while [ $# -gt 0 ]; do
        case "$1" in
            --bucket) shift; bucket="${1:-}"; shift || true ;;
            --limit)  shift; limit="${1:-10}"; shift || true ;;
            *)        shift ;;
        esac
    done

    SEARCH_QUERY="$query" SEARCH_BUCKET="$bucket" SEARCH_LIMIT="$limit" \
    INDEXER_URL="http://localhost:${INDEXER_PORT:-8900}" \
    python3 -c "
import os, json, sys
from urllib.request import Request, urlopen

query = os.environ['SEARCH_QUERY']
bucket = os.environ.get('SEARCH_BUCKET') or None
limit = int(os.environ.get('SEARCH_LIMIT', '10'))
indexer_url = os.environ['INDEXER_URL']

payload = json.dumps({'query': query, 'bucket': bucket, 'limit': limit}).encode()
req = Request(f'{indexer_url}/search', data=payload, headers={'Content-Type': 'application/json'})
try:
    resp = urlopen(req, timeout=10)
except Exception as e:
    print(f'ERROR: Indexer not reachable at {indexer_url} — {e}')
    sys.exit(1)
results = json.loads(resp.read())
if not results.get('results'):
    print('No results.')
    sys.exit(0)
for r in results['results']:
    score = f\"{r['score']:.3f}\"
    size = r.get('size', 0)
    for u in ['B','KB','MB','GB','TB']:
        if size < 1024: break
        size /= 1024
    size_str = f'{size:.0f} {u}'
    print(f'  {score}  s3://{r[\"bucket\"]}/{r[\"key\"]}  ({size_str})')
    preview = r.get('preview', '')[:120].replace(chr(10), ' ')
    if preview:
        print(f'         {preview}')
"
}

cmd_index() {
    [ -z "${1:-}" ] && { echo "Usage: databucket index <bucket>"; exit 1; }
    _s3_env
    local bucket="$1"

    echo "Indexing bucket: $bucket ..."
    INDEX_BUCKET="$bucket" INDEXER_URL="http://localhost:${INDEXER_PORT:-8900}" \
    python3 -c "
import os, json, sys
from urllib.request import Request, urlopen

bucket = os.environ['INDEX_BUCKET']
indexer_url = os.environ['INDEXER_URL']

req = Request(f'{indexer_url}/index/{bucket}', data=b'', method='POST',
              headers={'Content-Type': 'application/json'})
try:
    resp = urlopen(req, timeout=300)
except Exception as e:
    print(f'ERROR: Indexer not reachable — {e}')
    sys.exit(1)
result = json.loads(resp.read())
print(f\"Indexed: {result['indexed']}, Skipped: {result['skipped']}\")
"
}

# ============================================================
# HELP
# ============================================================

cmd_help() {
    cat <<'EOF'
databucket — unstructured data storage

Global flags:
  --as <user> [--password <pass>]     Run command as a specific user
                                      (prompts for password if omitted)

Service:
  databucket start                            Start services
  databucket stop                             Stop services
  databucket status                           Show service status
  databucket logs [service]                   Show logs
  databucket update                           Pull latest images & restart
  databucket info                             Show system overview

Buckets:
  databucket bucket list                      List all buckets
  databucket bucket create <name>             Create a bucket
  databucket bucket delete <name>             Delete a bucket
  databucket bucket info <name>               Show bucket stats

Data:
  databucket upload <file> <bucket> <key>     Upload a file
    [--metadata k=v,k=v] [--tags k=v,k=v]
  databucket download <bucket> <key> <out>    Download a file
  databucket ls <bucket> [prefix]             List objects
  databucket inspect <bucket> <key>           Show object metadata & tags

Users:
  databucket user list                        List all users
  databucket user create <name> [password]    Create a user (prompts if omitted)
  databucket user delete <name>               Delete a user
  databucket user info <name>                 Show user details
  databucket user policy <name> <policy>      Assign policy to user
  databucket user enable <name>               Enable a user
  databucket user disable <name>              Disable a user
  databucket user key create <name>           Generate API key for user
  databucket user key list <name>             List API keys for user
  databucket user key delete <access-key>     Revoke an API key

Policies:
  databucket policy list                      List all policies
  databucket policy info <name>               Show policy details
  databucket policy create <name> <json>      Create custom policy from JSON
  databucket policy delete <name>             Delete a custom policy
  Built-in: readonly, readwrite, writeonly, diagnostics

Search:
  databucket search <query>                   Semantic search across all data
    [--bucket <name>] [--limit <n>]
  databucket index <bucket>                   Re-index all objects in a bucket

Backup:
  databucket backup [target-dir]              Download all data to local dir

Examples:
  databucket user create analyst              # interactive password
  databucket policy create curated-ro p.json  # bucket-level access
  databucket user policy analyst curated-ro
  databucket --as analyst ls curated          # test as that user
EOF
}

# ============================================================
# ROUTING
# ============================================================

case "${1:-help}" in
    start)          cmd_start ;;
    stop)           cmd_stop ;;
    status)         cmd_status ;;
    logs)           shift; cmd_logs "$@" ;;
    update)         cmd_update ;;
    info)           cmd_info ;;
    inspect)        shift; cmd_inspect "$@" ;;
    bucket)
        case "${2:-}" in
            list)   cmd_bucket_list ;;
            create) cmd_bucket_create "${3:-}" ;;
            delete) cmd_bucket_delete "${3:-}" ;;
            info)   cmd_bucket_info "${3:-}" ;;
            *)      echo "Usage: databucket bucket list|create|delete|info [name]"; exit 1 ;;
        esac ;;
    upload)         shift; cmd_upload "$@" ;;
    download)       shift; cmd_download "$@" ;;
    ls)             shift; cmd_ls "$@" ;;
    user)
        case "${2:-}" in
            list)    cmd_user_list ;;
            create)  cmd_user_create "${3:-}" "${4:-}" ;;
            delete)  cmd_user_delete "${3:-}" ;;
            info)    cmd_user_info "${3:-}" ;;
            policy)  cmd_user_policy "${3:-}" "${4:-}" ;;
            enable)  cmd_user_enable "${3:-}" ;;
            disable) cmd_user_disable "${3:-}" ;;
            key)
                case "${3:-}" in
                    create) cmd_user_key_create "${4:-}" ;;
                    list)   cmd_user_key_list "${4:-}" ;;
                    delete) cmd_user_key_delete "${4:-}" ;;
                    *)      echo "Usage: databucket user key create|list|delete"; exit 1 ;;
                esac ;;
            *)       echo "Usage: databucket user list|create|delete|info|policy|enable|disable|key"; exit 1 ;;
        esac ;;
    policy)
        case "${2:-}" in
            list)   cmd_policy_list ;;
            info)   cmd_policy_info "${3:-}" ;;
            create) cmd_policy_create "${3:-}" "${4:-}" ;;
            delete) cmd_policy_delete "${3:-}" ;;
            *)      echo "Usage: databucket policy list|info|create|delete [name]"; exit 1 ;;
        esac ;;
    search)         shift; cmd_search "$@" ;;
    index)          shift; cmd_index "$@" ;;
    backup)         shift; cmd_backup "$@" ;;
    help|--help|-h) cmd_help ;;
    *)              echo "Unknown command: $1"; echo ""; cmd_help; exit 1 ;;
esac
