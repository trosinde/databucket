cmd_bucket_create() {
    [ -z "${1:-}" ] && { echo "Usage: databucket bucket create <name>"; exit 1; }
    _s3 "
s3.create_bucket(Bucket='$1')
print('Created: $1')
"
    # Enable auto-indexing for the new bucket (local mode only, best effort)
    if [ "$DATABUCKET_MODE" = "local" ]; then
        (
            _compose exec -T minio mc alias set local http://localhost:9000 "$AWS_ACCESS_KEY_ID" "$AWS_SECRET_ACCESS_KEY" --quiet 2>/dev/null &&
            _compose exec -T minio mc event add local/"$1" arn:minio:sqs::indexer:webhook --event put,delete 2>/dev/null &&
            echo "Auto-indexing enabled for: $1"
        ) 2>/dev/null || true
    fi
}

