#!/usr/bin/env bash
set -euo pipefail

DATABUCKET_HOME="${DATABUCKET_HOME:-/opt/databucket}"
DATABUCKET_USER=""
DATABUCKET_PASS=""
DATABUCKET_PROFILE=""
DATABUCKET_MODE="local"

# ============================================================
# GLOBAL FLAGS (parsed before command routing)
# ============================================================

_parse_global_flags() {
    local parsing_flags=true
    while [ $# -gt 0 ]; do
        if [ "$parsing_flags" = true ]; then
            case "$1" in
                --as)
                    shift
                    DATABUCKET_USER="${1:-}"
                    [ -z "$DATABUCKET_USER" ] && { echo "ERROR: --as requires a username"; exit 1; }
                    shift
                    if [ "${1:-}" = "--password" ]; then
                        shift; DATABUCKET_PASS="${1:-}"; shift
                    else
                        read -rsp "Password for $DATABUCKET_USER: " DATABUCKET_PASS; echo ""
                    fi
                    ;;
                --profile)
                    shift; DATABUCKET_PROFILE="${1:-}"; shift
                    [ -z "$DATABUCKET_PROFILE" ] && { echo "ERROR: --profile requires a name"; exit 1; }
                    ;;
                --endpoint)
                    shift; export DATABUCKET_ENDPOINT="${1:-}"; shift
                    ;;
                -*)  ARGS+=("$1"); shift ;;
                *)   parsing_flags=false; ARGS+=("$1"); shift ;;
            esac
        else
            ARGS+=("$1"); shift
        fi
    done
}

ARGS=()
_parse_global_flags "$@"
set -- "${ARGS[@]:-}"

# ============================================================
# HELPERS
# ============================================================

_compose() {
    docker compose -f "$DATABUCKET_HOME/docker-compose.yaml" --env-file "$DATABUCKET_HOME/.env" "$@"
}

_resolve_config() {
    # Already resolved?
    [ -n "${_CONFIG_RESOLVED:-}" ] && return
    _CONFIG_RESOLVED=1

    # 1. Explicit --endpoint flag
    if [ -n "${DATABUCKET_ENDPOINT:-}" ]; then
        export S3_ENDPOINT="$DATABUCKET_ENDPOINT"
        DATABUCKET_MODE="remote"
    fi

    # 2. Profile from config file
    local config="$HOME/.databucket/config"
    local profile="${DATABUCKET_PROFILE:-}"
    if [ -n "$profile" ] && [ -f "$config" ]; then
        eval "$(python3 -c "
import configparser, os
c = configparser.ConfigParser()
c.read(os.path.expanduser('~/.databucket/config'))
p = '$profile'
if c.has_section(p):
    for k, v in c.items(p):
        print(f'export DATABUCKET_{k.upper()}=\"{v}\"')
else:
    print(f'echo \"ERROR: Profile \"{p}\" not found in {os.path.expanduser(\"~/.databucket/config\")}\"; exit 1')
")"
        DATABUCKET_MODE="remote"
    elif [ -z "$profile" ] && [ -f "$config" ]; then
        # Try default profile silently
        eval "$(python3 -c "
import configparser, os
c = configparser.ConfigParser()
c.read(os.path.expanduser('~/.databucket/config'))
if c.has_section('default'):
    for k, v in c.items('default'):
        print(f'export DATABUCKET_{k.upper()}=\"{v}\"')
" 2>/dev/null)" || true
    fi

    # 3. Map config vars to S3 vars
    [ -n "${DATABUCKET_ENDPOINT:-}" ] && export S3_ENDPOINT="$DATABUCKET_ENDPOINT"
    [ -n "${DATABUCKET_ACCESS_KEY:-}" ] && export AWS_ACCESS_KEY_ID="$DATABUCKET_ACCESS_KEY"
    [ -n "${DATABUCKET_SECRET_KEY:-}" ] && export AWS_SECRET_ACCESS_KEY="$DATABUCKET_SECRET_KEY"
    [ -n "${DATABUCKET_INDEXER_URL:-}" ] && export INDEXER_URL="$DATABUCKET_INDEXER_URL"

    # 4. Fallback: local .env
    if [ -z "${S3_ENDPOINT:-}" ] && [ -f "$DATABUCKET_HOME/.env" ]; then
        set -a
        # shellcheck source=/dev/null
        source "$DATABUCKET_HOME/.env"
        set +a
        export S3_ENDPOINT="${S3_ENDPOINT:-http://localhost:${MINIO_API_PORT:-9000}}"
        export AWS_ACCESS_KEY_ID="${AWS_ACCESS_KEY_ID:-$MINIO_ROOT_USER}"
        export AWS_SECRET_ACCESS_KEY="${AWS_SECRET_ACCESS_KEY:-$MINIO_ROOT_PASSWORD}"
        DATABUCKET_MODE="local"
    fi

    # 5. Accept S3_ACCESS_KEY / S3_SECRET_KEY env vars (e.g. from test environment)
    [ -z "${AWS_ACCESS_KEY_ID:-}" ] && [ -n "${S3_ACCESS_KEY:-}" ] && export AWS_ACCESS_KEY_ID="$S3_ACCESS_KEY"
    [ -z "${AWS_SECRET_ACCESS_KEY:-}" ] && [ -n "${S3_SECRET_KEY:-}" ] && export AWS_SECRET_ACCESS_KEY="$S3_SECRET_KEY"
    [ -z "${S3_ENDPOINT:-}" ] && [ -n "${S3_ENDPOINT:-}" ] && true  # already set

    # --as user override
    if [ -n "$DATABUCKET_USER" ]; then
        export AWS_ACCESS_KEY_ID="$DATABUCKET_USER"
        export AWS_SECRET_ACCESS_KEY="$DATABUCKET_PASS"
    fi
}

_s3_env() { _resolve_config; }

_s3() {
    _resolve_config
    python3 -c "
import boto3, sys, json
from botocore.config import Config
s3 = boto3.client('s3', endpoint_url='$S3_ENDPOINT',
    aws_access_key_id='$AWS_ACCESS_KEY_ID',
    aws_secret_access_key='$AWS_SECRET_ACCESS_KEY',
    config=Config(signature_version='s3v4'))
$1
"
}

_admin() {
    _resolve_config
    ADMIN_ENDPOINT="$S3_ENDPOINT" ADMIN_ACCESS_KEY="$AWS_ACCESS_KEY_ID" \
    ADMIN_SECRET_KEY="$AWS_SECRET_ACCESS_KEY" \
    python3 -c "
import os, json, sys
from minio.minioadmin import MinioAdmin
from minio.credentials import StaticProvider

endpoint = os.environ['ADMIN_ENDPOINT'].replace('http://', '').replace('https://', '')
secure = os.environ['ADMIN_ENDPOINT'].startswith('https')
creds = StaticProvider(os.environ['ADMIN_ACCESS_KEY'], os.environ['ADMIN_SECRET_KEY'])
admin = MinioAdmin(endpoint=endpoint, credentials=creds, secure=secure)
$1
"
}

_require_local() {
    _resolve_config
    if [ "$DATABUCKET_MODE" = "remote" ]; then
        echo "ERROR: '$1' is only available locally (on the databucket host)."
        exit 1
    fi
}

