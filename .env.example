# MinIO root credentials
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=changeme-use-a-strong-password

# MCP service account (created by install.sh, restricted to readwrite)
MCP_ACCESS_KEY=mcp-service
MCP_SECRET_KEY=changeme-mcp-service-password

# MinIO ports (optional, defaults shown)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Semantic search (optional, defaults shown)
QDRANT_PORT=6333
INDEXER_PORT=8900
